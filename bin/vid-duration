#!/bin/bash

if [ $# -eq 0 ]; then
    cat <<EOF
Usage
    vid-duration *.mp4 *.mp3
Output
    duration.txt

Collect all duration.txt files in all dirs below current dir.

for i in $(find * -name duration.txt); do
    echo;
    echo ${i%/duration.txt};
    cat $i;
done >files.txt
EOF
    exit 1
fi

for i in $*; do
    if [ ! -f $i ]; then
        continue
    fi
    echo -n $i
    ffmpeg -i $i 2>&1 | grep Duration
done |
    sed 's/00://; s/\.[0-9]*,//' |
    awk '{print $1 "\t" $2,$3}' >duration.txt
